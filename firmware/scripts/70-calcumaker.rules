# Calcumaker 16 dev access — grant the local user raw-USB access (no sudo) for
# probe-rs (ST-Link), dfu-util (STM32 ROM bootloader), and the app's own device.
#
# ST-Link V2 / V2.1 / V3 (probe-rs, cargo flash/embed)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="3744|3748|374a|374b|374d|374e|374f|3752|3753", MODE="0666", TAG+="uaccess"
# STM32 system ROM bootloader — USB DFU (dfu-util: `make dfu`)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0666", TAG+="uaccess"
# Calcumaker 16 application (composite CDC-ACM console + HID keyboard)
SUBSYSTEM=="usb", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="c160", MODE="0666", TAG+="uaccess"
