	)
	(text "Calcumaker 16 display — OPTIONAL aux OLED (DNP by default). J2 receives a standard 0.91\" SSD1306 128x32 I2C module (VCC GND SCL SDA; module sourced separately, hand-placed with the THT digits). Wiring: J2.1 VCC <- J1.8 (+3V3), J2.2 GND, J2.3 SCL <- J1.10, J2.4 SDA <- J1.9. I2C runs at 3V3 straight from the MCU (pull-ups on the main board, DNP alongside). Firmware sleeps the panel in idle (~10uA). Shows full error text / SETUP / STATUS; the 7-seg glass stays primary (Error N codes)."
		(exclude_from_sim no)
		(at 15.00 80.00 0)
		(effects (font (size 1.5 1.5)) (justify left top))
