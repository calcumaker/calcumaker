	(text "LOCAL 5V RAIL + LEVEL SHIFT  -  PLACED, not wired\nMoved off the MCU board so the unified FFC stays technology-agnostic.\n\n5V BOOST  U5 TPS61022 (C915088): VIN<-VSYS (J1), L1 1uH (C5832342),\n  Cin C13 10uF, Cout C14/C15 2x22uF; FB R2 732k/R3 100k -> +5V (Vref 0.6V).\n  EN -> +5V-always (or a G0 GPIO to gate the display off in deep sleep).\nSHIFT     U6 74HCT125 @ +5V: IN <- G0 CLK/DIN1/DIN2/DIN3 (3V3);  OUT ->\n  DISP_CLK + DIN1/2/3 at 5V logic to the TM1640s (Row1-3). /OE all low.\n  C16 100nF VCC decouple. (TM1640 VIH=0.7*5=3.5V > 3V3, hence the shift.)"
		(exclude_from_sim no)
		(at 15.00 130.00 0)
		(effects (font (face "Courier New") (size 1.27 1.27)) (justify left top))
		(uuid "e9e297f6-cbfc-4a79-8b23-e689bf9491f2")
	)
	(sheet_instances
		(path "/"
			(page "9")
		)
	)
	(embedded_fonts no)
)
